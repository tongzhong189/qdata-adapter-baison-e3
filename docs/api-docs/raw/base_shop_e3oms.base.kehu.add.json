            {
              "code": "lsd_ck_fee",
              "type": "number",
              "required": false,
              "desc": "零售订单-仓储费",
              "example": 100
            },
            {
              "code": "lsd_db_fee",
              "type": "number",
              "required": false,
              "desc": "零售订单-拆包费",
              "example": 5
