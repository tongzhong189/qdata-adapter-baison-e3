              "desc": "零售订单-物流费用类型 0：按运费设置计算运费；1：固定运费",
              "example": 1
            },
            {
              "code": "lsd_wl_fee",
              "type": "number",
              "required": false,
              "desc": "零售订单-物流费（零售订单-物流费为【固定运费】时可传）",
              "example": 10
            },
            {
              "code": "lst_jsj",
              "type": "number",
              "required": false,
              "desc": "零售退单-结算价格项(选项同：零售订单-结算价格项)",
